generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==================
// SCHOOLS
// ==================
model School {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  address   String
  type      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  students  Student[]
  teachers  Teacher[]
  classes   Class[]
  announcements  Announcement[]
}

// ==================
// USERS (Admin, Teacher, Parent, Student)
// ==================
model User {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  email     String   @unique
  password  String
  role      String   // "superadmin" | "schooladmin" | "teacher" | "student" | "parent"
  createdAt DateTime @default(now())

  school    School?  @relation(fields: [schoolId], references: [id])
  schoolId  String?
}

// ==================
// STUDENTS
// ==================
model Student {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  studentId String   @unique
  class     Class?   @relation(fields: [classId], references: [id])
  classId   String?
  school    School   @relation(fields: [schoolId], references: [id])
  schoolId  String
  createdAt DateTime @default(now())

 grades     Grade[]
  attendance Attendance[]
  fees       Fee[]
  parents    ParentStudent[]
}

// ==================
// TEACHERS
// ==================
model Teacher {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  email     String   @unique
  subject   String
  school    School   @relation(fields: [schoolId], references: [id])
  schoolId  String
  createdAt DateTime @default(now())
  timetable   Timetable[]

  classes   Class[]
}

// ==================
// CLASSES
// ==================
model Class {
  id        String   @id @default(cuid())
  name      String
  level     String   // "primary" | "secondary"
  school    School   @relation(fields: [schoolId], references: [id])
  schoolId  String
  teacher   Teacher? @relation(fields: [teacherId], references: [id])
  teacherId String?
  createdAt DateTime @default(now())
  timetable   Timetable[]

  students  Student[]
}

// ==================
// GRADES
// ==================
model Grade {
  id        String   @id @default(cuid())
  subject   String
  score     Float
  term      String
  student   Student  @relation(fields: [studentId], references: [id])
  studentId String
  createdAt DateTime @default(now())
}

// ==================
// ATTENDANCE
// ==================
model Attendance {
  id        String   @id @default(cuid())
  date      DateTime
  status    String   // "present" | "absent" | "late"
  student   Student  @relation(fields: [studentId], references: [id])
  studentId String
  createdAt DateTime @default(now())
}
// ==================
// ANNOUNCEMENTS
// ==================
model Announcement {
  id        String   @id @default(cuid())
  title     String
  content   String
  school    School   @relation(fields: [schoolId], references: [id])
  schoolId  String
  createdAt DateTime @default(now())
}
model Fee {
  id          String   @id @default(cuid())
  student     Student  @relation(fields: [studentId], references: [id])
  studentId   String
  amount      Float
  description String
  status      String   @default("unpaid")
  dueDate     DateTime
  paidDate    DateTime?
  term        String
  createdAt   DateTime @default(now())
}
model Timetable {
  id        String   @id @default(cuid())
  class     Class    @relation(fields: [classId], references: [id])
  classId   String
  day       String
  subject   String
  startTime String
  endTime   String
  teacher   Teacher  @relation(fields: [teacherId], references: [id])
  teacherId String
  createdAt DateTime @default(now())
}
// ==================
// PARENTS
// ==================
model Parent {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  email     String   @unique
  password  String
  phone     String?
  createdAt DateTime @default(now())

  children  ParentStudent[]
}

model ParentStudent {
  id        String  @id @default(cuid())
  parent    Parent  @relation(fields: [parentId], references: [id])
  parentId  String
  student   Student @relation(fields: [studentId], references: [id])
  studentId String
}